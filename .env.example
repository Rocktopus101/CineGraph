# Database (local Docker)
DATABASE_URL=postgresql+asyncpg://cinegraph:cinegraph@db:5432/cinegraph
# Production (Neon free tier — no Cloud SQL billing):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxxx.region.aws.neon.tech/neondb?ssl=require

# LLM provider: gemini (default) | openai | local
LLM_PROVIDER=gemini
EMBEDDING_DIM=768

# Gemini — free tier key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Gemini free-tier embedding throttle (100 RPM, 30k TPM, 1k RPD)
EMBEDDING_BATCH_SIZE=8
EMBEDDING_RPM_LIMIT=60
EMBEDDING_MIN_DELAY_SECONDS=1.5
EMBEDDING_MAX_RETRIES=12
EMBEDDING_MAX_CHUNK_CHARS=600
# Set true to embed every diary entry during import (slow on Gemini free tier)
IMPORT_EMBED_USER_HISTORY=false

# OpenAI (optional — set LLM_PROVIDER=openai and EMBEDDING_DIM=1536)
OPENAI_API_KEY=sk-your-openai-key
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# TMDB
TMDB_API_KEY=your-tmdb-api-key

# Firebase Admin SDK (backend)
# Render/production: prefer pasting the full JSON file as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS (comma-separated; add production frontend URL when deploying)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Vercel preview deploys use unique subdomains — regex covers them on Render
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Development bypass (skip Firebase auth + onboarding)
# Set both to false for production / real Firebase auth testing
DEV_MODE=true
DEV_SKIP_ONBOARDING=true
DEV_FIREBASE_UID=dev-user-local
DEV_ADMIN=true

# Frontend (client-side Firebase config)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_DEV_MODE=true

# --- Production overrides ---
# DEV_MODE=false
# NEXT_PUBLIC_DEV_MODE=false
# Path B (Neon + Render + Vercel — no Cloud SQL):
# NEXT_PUBLIC_API_URL=https://cinegraph-api.onrender.com
# CORS_ORIGINS=https://your-app.vercel.app
# Path A (Cloud Run + App Hosting):
# NEXT_PUBLIC_API_URL=https://cinegraph-api-xxxxx-uc.a.run.app
# CORS_ORIGINS=https://your-app--your-project.us-central1.hosted.app
# See docs/FIREBASE_DEPLOYMENT.md for full setup
